# ─────────────────────────────────────────────
# nStore Secure CRUD Backend – Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nstore_crud?retryWrites=true&w=majority

# JWT secret – use a long random string (32+ chars)
JWT_SECRET=replace_with_a_very_long_random_secret_string_here
JWT_EXPIRES_IN=7d

# AI Integration (Phase 10)
AI_API_KEY=your_grok_or_openai_api_key_here
AI_API_URL=https://api.x.ai/v1/chat/completions

# Allowed frontend origin for CORS
CLIENT_URL=http://localhost:5173
