{
  "info": {
    "name": "nStore Secure CRUD API",
    "description": "Complete API collection for nStore Employee Management System. Includes Auth, CRUD, and AI endpoints. Import this file into Postman.\n\nBase URL: http://localhost:5000\n\nSetup:\n1. Register a user\n2. Login to get token\n3. Set the token in the 'token' variable\n4. Run CRUD operations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "nstore-crud-collection-v1"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "employee_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Admin\",\n  \"email\": \"admin@nstore.com\",\n  \"password\": \"SecurePass1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user. The first user created automatically becomes admin."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.test('Registration successful', () => pm.expect(pm.response.code).to.equal(201));",
                  "  pm.test('Token received', () => pm.expect(json.token).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@nstore.com\",\n  \"password\": \"SecurePass1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login and get JWT token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.test('Login successful', () => pm.expect(pm.response.code).to.equal(200));",
                  "  pm.test('Token received', () => pm.expect(json.token).to.be.a('string'));",
                  "  pm.test('User has role', () => pm.expect(json.user.role).to.be.oneOf(['user', 'admin']));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login – Wrong Password (Should Fail)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@nstore.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Should return 401 with generic message (OWASP)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Correct 401 status', () => pm.expect(pm.response.code).to.equal(401));",
                  "pm.test('Generic error message', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.equal('Invalid email or password.');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('No password in response', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.user.password).to.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Johnson\",\n  \"email\": \"alice.johnson@nstore.com\",\n  \"department\": \"Engineering\",\n  \"position\": \"Senior Developer\",\n  \"salary\": 950000,\n  \"phone\": \"+91 98765 43210\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/employees",
              "host": ["{{base_url}}"],
              "path": ["api", "employees"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('employee_id', json.employee._id);",
                  "  pm.test('Employee created', () => pm.expect(pm.response.code).to.equal(201));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Employee – Validation Error",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"email\": \"not-an-email\",\n  \"salary\": -100\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/employees",
              "host": ["{{base_url}}"],
              "path": ["api", "employees"]
            },
            "description": "Should return 400 with validation errors."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Validation error 400', () => pm.expect(pm.response.code).to.equal(400));",
                  "pm.test('Errors array present', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.errors).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/employees?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "employees"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Pagination present', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.pagination).to.have.property('total');",
                  "  pm.expect(json.pagination).to.have.property('pages');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Employees – Search",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/employees?search=alice&department=Engineering",
              "host": ["{{base_url}}"],
              "path": ["api", "employees"],
              "query": [
                { "key": "search", "value": "alice" },
                { "key": "department", "value": "Engineering" }
              ]
            }
          }
        },
        {
          "name": "Get Single Employee",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/employees/{{employee_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "employees", "{{employee_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Employee has required fields', () => {",
                  "  const emp = pm.response.json().employee;",
                  "  pm.expect(emp).to.have.property('name');",
                  "  pm.expect(emp).to.have.property('department');",
                  "  pm.expect(emp).to.have.property('salary');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"position\": \"Principal Engineer\",\n  \"salary\": 1200000,\n  \"department\": \"Engineering\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/employees/{{employee_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "employees", "{{employee_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Employee updated', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.include('updated');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Employee (Admin only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/employees/{{employee_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "employees", "{{employee_id}}"]
            },
            "description": "Only admin role can delete. User role returns 403."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Delete successful or forbidden (RBAC test)', () => {",
                  "  pm.expect([200, 403]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Unauthorized – No Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/employees",
              "host": ["{{base_url}}"],
              "path": ["api", "employees"]
            },
            "description": "Should return 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Unauthorized 401', () => pm.expect(pm.response.code).to.equal(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "AI Integration",
      "item": [
        {
          "name": "AI Employee Summary",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee\": {\n    \"name\": \"Alice Johnson\",\n    \"department\": \"Engineering\",\n    \"position\": \"Senior Developer\",\n    \"salary\": 950000\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/ai-summary",
              "host": ["{{base_url}}"],
              "path": ["api", "ai-summary"]
            },
            "description": "Calls Grok/xAI or mock AI to generate employee summary. AI key stored securely in .env."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('AI summary returned', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Summary is string', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.summary).to.be.a('string');",
                  "  pm.expect(json.summary.length).to.be.greaterThan(10);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": ["{{base_url}}"],
              "path": ["api", "health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Server is up', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Status ok', () => pm.expect(pm.response.json().status).to.equal('ok'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
